# ---------------------------------------------------------------------------
# SECURITY — never commit secrets or credentials
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets/
credentials/
**/*_secret*
**/*_credentials*

